<script define:vars={{ typingLines: [t.hero.typing_line1, t.hero.typing_line2, t.hero.typing_line3], formSuccess: t.contacto.form_success, heroSlideDurationMs }}>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      menuBtn.setAttribute('aria-expanded', String(!isOpen));
      const lines = menuBtn.querySelectorAll('.mobile-menu-line');
      if (!isOpen) {
        lines[0]?.classList.add('translate-y-[4px]', 'rotate-45');
        lines[1]?.classList.add('opacity-0');
        lines[2]?.classList.add('-translate-y-[4px]', '-rotate-45');
      } else {
        lines[0]?.classList.remove('translate-y-[4px]', 'rotate-45');
        lines[1]?.classList.remove('opacity-0');
        lines[2]?.classList.remove('-translate-y-[4px]', '-rotate-45');
      }
    });

    mobileMenu.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
        const lines = menuBtn.querySelectorAll('.mobile-menu-line');
        lines[0]?.classList.remove('translate-y-[4px]', 'rotate-45');
        lines[1]?.classList.remove('opacity-0');
        lines[2]?.classList.remove('-translate-y-[4px]', '-rotate-45');
      });
    });
  }

  // Smooth scroll
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      e.preventDefault();
      const href = this.getAttribute('href');
      if (href) {
        const target = document.querySelector(href);
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // Intersection Observer
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animate-fade-in-up');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.card-brutal').forEach(el => {
    el.style.opacity = '0';
    observer.observe(el);
  });

  // HUD Clock
  const clockEl = document.getElementById('hud-clock');
  if (clockEl) {
    const updateClock = () => {
      clockEl.textContent = new Date().toLocaleTimeString('es-ES', { hour12: false });
    };
    updateClock();
    setInterval(updateClock, 1000);
  }

  // Typing effect
  const typingEl = document.getElementById('typing-text');
  if (typingEl) {
    let lineIdx = 0, charIdx = 0, currentText = '';
    const typeChar = () => {
      if (lineIdx >= typingLines.length) return;
      if (charIdx < typingLines[lineIdx].length) {
        currentText += typingLines[lineIdx][charIdx];
        typingEl.textContent = currentText;
        charIdx++;
        setTimeout(typeChar, 30 + Math.random() * 40);
      } else {
        currentText += '\n';
        lineIdx++;
        charIdx = 0;
        if (lineIdx < typingLines.length) setTimeout(typeChar, 400);
      }
    };
    setTimeout(typeChar, 1200);
  }

  // Hero Slider
  const heroSlides = document.querySelectorAll('.hero-slide');
  const heroDots = document.querySelectorAll('.hero-dot');
  const heroProgress = document.getElementById('hero-progress');
  const heroCounter = document.getElementById('hero-slide-counter');
  const SLIDE_DURATION = heroSlideDurationMs;
  let currentSlide = 0;
  let slideTimer = null;

  function setSlide(idx) {
    heroSlides.forEach((s, i) => s.classList.toggle('active', i === idx));
    heroDots.forEach((d, i) => d.classList.toggle('active', i === idx));
    if (heroCounter) heroCounter.textContent = `0${idx + 1} / 0${heroSlides.length}`;
    currentSlide = idx;
    startProgress();
  }

  function startProgress() {
    if (!heroProgress) return;
    heroProgress.classList.remove('running');
    heroProgress.style.transitionDuration = '0ms';
    heroProgress.style.width = '0%';
    void heroProgress.offsetWidth;
    heroProgress.style.transitionDuration = `${SLIDE_DURATION}ms`;
    heroProgress.classList.add('running');
    heroProgress.style.width = '100%';
    if (slideTimer) clearTimeout(slideTimer);
    slideTimer = setTimeout(() => setSlide((currentSlide + 1) % heroSlides.length), SLIDE_DURATION);
  }

  heroDots.forEach(dot => {
    dot.addEventListener('click', () => setSlide(parseInt(dot.dataset.slide || '0', 10)));
  });

  if (heroSlides.length > 1) startProgress();

  // Contact form
  const contactForm = document.getElementById('contact-form');
  const terminalOutput = document.getElementById('terminal-output');
  if (contactForm && terminalOutput) {
    contactForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = document.getElementById('contact-name')?.value || '';
      const email = document.getElementById('contact-email')?.value || '';
      const project = document.getElementById('contact-project')?.value || '';
      const message = document.getElementById('contact-message')?.value || '';

      const esc = (s) => { const d = document.createElement('span'); d.textContent = s; return d.innerHTML; };
      const echo = document.createElement('div');
      echo.innerHTML = `
        <div class="mt-4 text-cyber-teal">$ send_project --from="${esc(name)}"</div>
        <div class="mt-1 text-cyber-text/80">
          <div><span class="text-cyber-orange">FROM:</span> ${esc(name)} &lt;${esc(email)}&gt;</div>
          <div><span class="text-cyber-orange">TYPE:</span> ${esc(project)}</div>
          <div><span class="text-cyber-orange">MSG:</span> ${esc(message.slice(0, 80))}${message.length > 80 ? '...' : ''}</div>
          <div class="mt-1 text-cyber-teal">&#10003; ${formSuccess}</div>
        </div>
      `;
      const lastLine = terminalOutput.querySelector(':scope > div:last-child');
      if (lastLine) lastLine.remove();
      terminalOutput.appendChild(echo);

      const cursor = document.createElement('div');
      cursor.className = 'mt-4 text-cyber-teal';
      cursor.innerHTML = '$ <span class="typing-cursor text-cyber-orange">█</span>';
      terminalOutput.appendChild(cursor);
      contactForm.reset();
      window.location.href = `mailto:hola@cibai.studio?subject=Proyecto: ${project}&body=Nombre: ${name}%0AEmail: ${email}%0A%0A${encodeURIComponent(message)}`;
    });
  }
</script>
