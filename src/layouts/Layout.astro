---
import type { Locale } from '../i18n';
import { getTranslations } from '../i18n';
import { loadSettings, lightenColor } from '../lib/settings';

interface Props {
  title: string;
  description: string;
  locale?: Locale;
  canonicalPath?: string;
  isHome?: boolean;
  pageSchema?: object;
}

const { title, description, locale = 'es', canonicalPath, isHome = false, pageSchema } = Astro.props;
const t = getTranslations(locale);
const siteUrl = 'https://cibai.studio';
const canonicalUrl = canonicalPath ? `${siteUrl}${canonicalPath}` : siteUrl;
const ogLocale = locale === 'ca' ? 'ca_ES' : 'es_ES';
const settings = loadSettings();
const primaryColor = settings.visual.primaryColor;
const primaryColorLight = lightenColor(primaryColor, 30);
const secondaryColor = settings.visual.secondaryColor;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "CIBAI.Studio",
  "url": siteUrl,
  "logo": `${siteUrl}/favicon.svg`,
  "description": "Estudio especializado en IA, automatización, software a medida y activos digitales para empresas.",
  "foundingDate": "2024",
  "founders": [
    {
      "@type": "Person",
      "name": "Matías Oliver",
      "jobTitle": "Founder & Strategy Lead"
    }
  ],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Barcelona",
    "addressCountry": "ES"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "availableLanguage": ["Spanish", "Catalan"],
    "url": `${siteUrl}/contacto`
  },
  "email": "hola@cibai.studio",
  "sameAs": [
    "https://www.linkedin.com/company/cibai-studio",
    "https://instagram.com/cibai.studio"
  ]
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "CIBAI.Studio",
  "url": siteUrl,
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${siteUrl}/?s={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${siteUrl}/og-image.jpg`} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="CIBAI Studio" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.jpg`} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>

    <!-- Dynamic overrides from admin settings -->
    <style set:html={`
      :root {
        --color-cyber-orange: ${primaryColor};
        --color-cyber-orange-light: ${primaryColorLight};
        --color-cyber-teal: ${secondaryColor};
      }
      /* Typography overrides */
      h1 { font-family: ${settings.typography.h1.fontFamily}; font-size: ${settings.typography.h1.fontSize}; font-weight: ${settings.typography.h1.fontWeight}; line-height: ${settings.typography.h1.lineHeight}; letter-spacing: ${settings.typography.h1.letterSpacing}; }
      h2 { font-family: ${settings.typography.h2.fontFamily}; font-size: ${settings.typography.h2.fontSize}; font-weight: ${settings.typography.h2.fontWeight}; line-height: ${settings.typography.h2.lineHeight}; letter-spacing: ${settings.typography.h2.letterSpacing}; }
      h3 { font-family: ${settings.typography.h3.fontFamily}; font-size: ${settings.typography.h3.fontSize}; font-weight: ${settings.typography.h3.fontWeight}; line-height: ${settings.typography.h3.lineHeight}; letter-spacing: ${settings.typography.h3.letterSpacing}; }
      h4 { font-family: ${settings.typography.h4.fontFamily}; font-size: ${settings.typography.h4.fontSize}; font-weight: ${settings.typography.h4.fontWeight}; line-height: ${settings.typography.h4.lineHeight}; letter-spacing: ${settings.typography.h4.letterSpacing}; }
      h5 { font-family: ${settings.typography.h5.fontFamily}; font-size: ${settings.typography.h5.fontSize}; font-weight: ${settings.typography.h5.fontWeight}; line-height: ${settings.typography.h5.lineHeight}; letter-spacing: ${settings.typography.h5.letterSpacing}; }
      h6 { font-family: ${settings.typography.h6.fontFamily}; font-size: ${settings.typography.h6.fontSize}; font-weight: ${settings.typography.h6.fontWeight}; line-height: ${settings.typography.h6.lineHeight}; letter-spacing: ${settings.typography.h6.letterSpacing}; }
      p { font-family: ${settings.typography.p.fontFamily}; font-size: ${settings.typography.p.fontSize}; font-weight: ${settings.typography.p.fontWeight}; line-height: ${settings.typography.p.lineHeight}; letter-spacing: ${settings.typography.p.letterSpacing}; }
      span.typo-override { font-family: ${settings.typography.span.fontFamily}; font-size: ${settings.typography.span.fontSize}; font-weight: ${settings.typography.span.fontWeight}; line-height: ${settings.typography.span.lineHeight}; letter-spacing: ${settings.typography.span.letterSpacing}; }
    `}></style>
    {settings.visual.customCSS && <style set:html={settings.visual.customCSS}></style>}

    <!-- Organization Schema (all pages) -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

    <!-- WebSite Schema (home only) -->
    {isHome && <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />}

    <!-- Page-specific Schema -->
    {pageSchema && <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />}
  </head>
  <body class="bg-cyber-black text-cyber-white">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-cyber-orange focus:text-cyber-black focus:font-mono focus:text-sm">
      {t.nav.skip_content}
    </a>
    <div class="scanline"></div>
    <slot />
  </body>
</html>
