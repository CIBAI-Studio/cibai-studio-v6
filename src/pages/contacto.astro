---
import Layout from '../layouts/Layout.astro';
import ContactoPage from '../components/ContactoPage.astro';
import '../styles/global.css';
import { getTranslations } from '../i18n';

const t = getTranslations('es');

const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contacto — CIBAI.Studio",
  "url": "https://cibai.studio/contacto",
  "description": "Solicita un diagnóstico inicial para identificar oportunidades de IA, automatización y software en tu empresa.",
  "mainEntity": {
    "@type": "Organization",
    "name": "CIBAI.Studio",
    "url": "https://cibai.studio"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": "https://cibai.studio/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Contacto",
      "item": "https://cibai.studio/contacto"
    }
  ]
};

const combinedSchema = [contactPageSchema, breadcrumbSchema];
---

<Layout
  title={t.meta.contacto_title}
  description={t.meta.contacto_description}
  locale="es"
  canonicalPath="/contacto"
  pageSchema={combinedSchema}
>
  <ContactoPage locale="es" />
</Layout>
