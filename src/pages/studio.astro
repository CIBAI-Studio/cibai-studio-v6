---
import Layout from '../layouts/Layout.astro';
import StudioPage from '../components/StudioPage.astro';
import '../styles/global.css';
import { getTranslations } from '../i18n';

const t = getTranslations('es');

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Matías Oliver",
  "jobTitle": "Founder & Strategy Lead",
  "worksFor": {
    "@type": "Organization",
    "name": "CIBAI.Studio",
    "url": "https://cibai.studio"
  },
  "description": "Especializado en IA aplicada, automatización y estrategia orientada a negocio. Lidera la visión de CIBAI.Studio.",
  "url": "https://cibai.studio/studio"
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": "https://cibai.studio/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Studio",
      "item": "https://cibai.studio/studio"
    }
  ]
};

const combinedSchema = [personSchema, breadcrumbSchema];
---

<Layout
  title={t.meta.studio_title}
  description={t.meta.studio_description}
  locale="es"
  canonicalPath="/studio"
  pageSchema={combinedSchema}
>
  <StudioPage locale="es" />
</Layout>
