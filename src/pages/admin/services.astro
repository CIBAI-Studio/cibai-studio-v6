---
import AdminLayout from '../../layouts/AdminLayout.astro';
import '../../styles/global.css';
import { getAuthUser } from '../../lib/auth';
import { loadSettings, saveSettings, generateId, type ServiceItem } from '../../lib/settings';
import { locales, getLocaleLabels } from '../../i18n';

const user = getAuthUser(Astro.cookies);
if (!user) return Astro.redirect('/admin/login');

const settings = loadSettings();
let successMessage = '';
let errorMessage = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('_action') as string;

  if (action === 'save_all') {
    const serviceIds = formData.getAll('service_id') as string[];
    const updatedServices: ServiceItem[] = [];

    for (const id of serviceIds) {
      const existing = settings.services.find(s => s.id === id);
      if (!existing) continue;

      const svc: ServiceItem = {
        id,
        num: (formData.get(`num_${id}`) as string) || existing.num,
        label: {} as Record<string, string>,
        title: {} as Record<string, string>,
        description: {} as Record<string, string>,
        tags: ((formData.get(`tags_${id}`) as string) || '').split(',').map(t => t.trim()).filter(Boolean),
        colors: {
          numColor: (formData.get(`color_num_${id}`) as string) || existing.colors.numColor,
          labelColor: (formData.get(`color_label_${id}`) as string) || existing.colors.labelColor,
          titleColor: (formData.get(`color_title_${id}`) as string) || existing.colors.titleColor,
          descriptionColor: (formData.get(`color_desc_${id}`) as string) || existing.colors.descriptionColor,
          hoverBorderColor: (formData.get(`color_hover_${id}`) as string) || existing.colors.hoverBorderColor,
          tagBorderColor: (formData.get(`color_tag_${id}`) as string) || existing.colors.tagBorderColor,
        },
      };

      for (const loc of locales) {
        svc.label[loc] = (formData.get(`label_${loc}_${id}`) as string) || '';
        svc.title[loc] = (formData.get(`title_${loc}_${id}`) as string) || '';
        svc.description[loc] = (formData.get(`desc_${loc}_${id}`) as string) || '';
      }

      updatedServices.push(svc);
    }

    settings.services = updatedServices;
    saveSettings(settings);
    successMessage = 'Servicios guardados correctamente.';
  }

  if (action === 'create') {
    const newSvc: ServiceItem = {
      id: generateId(),
      num: String(settings.services.length + 1).padStart(2, '0'),
      label: { es: 'NUEVO_SERVICIO', ca: 'NOU_SERVEI' },
      title: { es: 'Nuevo Servicio', ca: 'Nou Servei' },
      description: { es: 'Descripción del servicio.', ca: 'Descripció del servei.' },
      tags: ['TAG1', 'TAG2'],
      colors: {
        numColor: '#FFFFFF12',
        labelColor: settings.visual.secondaryColor,
        titleColor: '#F5F5F5',
        descriptionColor: '#888888',
        hoverBorderColor: settings.visual.primaryColor,
        tagBorderColor: '#2a2a2a',
      },
    };
    settings.services.push(newSvc);
    saveSettings(settings);
    successMessage = 'Servicio creado. Edítalo a continuación.';
  }

  if (action === 'delete') {
    const deleteId = formData.get('delete_id') as string;
    settings.services = settings.services.filter(s => s.id !== deleteId);
    saveSettings(settings);
    successMessage = 'Servicio eliminado.';
  }

  if (action === 'reorder') {
    const order = (formData.get('order') as string || '').split(',').filter(Boolean);
    const reordered: ServiceItem[] = [];
    for (const id of order) {
      const svc = settings.services.find(s => s.id === id);
      if (svc) reordered.push(svc);
    }
    if (reordered.length === settings.services.length) {
      settings.services = reordered;
      saveSettings(settings);
      successMessage = 'Orden actualizado.';
    }
  }
}

const localeLabels = getLocaleLabels();
const services = settings.services;
---

<AdminLayout title="Servicios" userName={user.name}>
  <div class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-black tracking-tight mb-2">Servicios</h1>
      <p class="text-sm text-cyber-text">Gestiona los servicios que se muestran en el frontend. Cada servicio se traduce a todos los idiomas.</p>
    </div>
    <form method="POST">
      <input type="hidden" name="_action" value="create" />
      <button type="submit" class="btn-primary text-xs py-2 px-5">
        + Nuevo servicio
      </button>
    </form>
  </div>

  {successMessage && (
    <div class="mb-6 px-4 py-3 border border-cyber-teal/30 bg-cyber-teal/5 text-cyber-teal font-mono text-xs">
      {successMessage}
    </div>
  )}

  <form method="POST">
    <input type="hidden" name="_action" value="save_all" />

    {services.map((svc, idx) => (
      <div class="card-brutal p-6 mb-6">
        <input type="hidden" name="service_id" value={svc.id} />

        <div class="flex items-center justify-between mb-6">
          <h2 class="font-mono text-sm font-bold text-cyber-white">
            <span class="text-cyber-orange">{svc.num}</span> — {svc.title.es}
          </h2>
          <button
            type="button"
            class="font-mono text-[10px] text-cyber-red hover:text-cyber-red/80 uppercase tracking-widest transition-colors delete-btn"
            data-id={svc.id}
            data-name={svc.title.es}
          >
            Eliminar
          </button>
        </div>

        {/* --- Basic Fields --- */}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
          <div>
            <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Número</label>
            <input type="text" name={`num_${svc.id}`} value={svc.num}
              class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors" />
          </div>
          <div class="md:col-span-2">
            <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Tags (separados por coma)</label>
            <input type="text" name={`tags_${svc.id}`} value={svc.tags.join(', ')}
              class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors" />
          </div>
        </div>

        {/* --- Translations per locale --- */}
        {locales.map((loc) => (
          <div class="mb-6 p-4 border border-cyber-border/50 bg-cyber-black/50">
            <div class="font-mono text-[10px] text-cyber-orange uppercase tracking-widest mb-3">{localeLabels[loc]} ({loc.toUpperCase()})</div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-3">
              <div>
                <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Label</label>
                <input type="text" name={`label_${loc}_${svc.id}`} value={svc.label[loc] || ''}
                  class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors" />
              </div>
              <div>
                <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Título</label>
                <input type="text" name={`title_${loc}_${svc.id}`} value={svc.title[loc] || ''}
                  class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors" />
              </div>
            </div>
            <div>
              <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Descripción</label>
              <textarea name={`desc_${loc}_${svc.id}`} rows="3"
                class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors resize-none"
              >{svc.description[loc] || ''}</textarea>
            </div>
          </div>
        ))}

        {/* --- Colors --- */}
        <details class="group">
          <summary class="font-mono text-[10px] text-cyber-text uppercase tracking-widest cursor-pointer hover:text-cyber-white transition-colors mb-4">
            ▸ Colores personalizados
          </summary>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4 pt-2">
            <div>
              <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Color número</label>
              <div class="flex items-center gap-2">
                <input type="color" value={svc.colors.numColor.length === 7 ? svc.colors.numColor : '#FFFFFF'}
                  class="w-8 h-8 border border-cyber-border bg-cyber-black cursor-pointer"
                  oninput={`this.nextElementSibling.value=this.value`} />
                <input type="text" name={`color_num_${svc.id}`} value={svc.colors.numColor}
                  class="flex-1 bg-cyber-black border border-cyber-border px-2 py-1 font-mono text-xs text-cyber-white focus:border-cyber-orange focus:outline-none" />
              </div>
            </div>
            <div>
              <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Color label</label>
              <div class="flex items-center gap-2">
                <input type="color" value={svc.colors.labelColor}
                  class="w-8 h-8 border border-cyber-border bg-cyber-black cursor-pointer"
                  oninput={`this.nextElementSibling.value=this.value`} />
                <input type="text" name={`color_label_${svc.id}`} value={svc.colors.labelColor}
                  class="flex-1 bg-cyber-black border border-cyber-border px-2 py-1 font-mono text-xs text-cyber-white focus:border-cyber-orange focus:outline-none" />
              </div>
            </div>
            <div>
              <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Color título</label>
              <div class="flex items-center gap-2">
                <input type="color" value={svc.colors.titleColor}
                  class="w-8 h-8 border border-cyber-border bg-cyber-black cursor-pointer"
                  oninput={`this.nextElementSibling.value=this.value`} />
                <input type="text" name={`color_title_${svc.id}`} value={svc.colors.titleColor}
                  class="flex-1 bg-cyber-black border border-cyber-border px-2 py-1 font-mono text-xs text-cyber-white focus:border-cyber-orange focus:outline-none" />
              </div>
            </div>
            <div>
              <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Color descripción</label>
              <div class="flex items-center gap-2">
                <input type="color" value={svc.colors.descriptionColor}
                  class="w-8 h-8 border border-cyber-border bg-cyber-black cursor-pointer"
                  oninput={`this.nextElementSibling.value=this.value`} />
                <input type="text" name={`color_desc_${svc.id}`} value={svc.colors.descriptionColor}
                  class="flex-1 bg-cyber-black border border-cyber-border px-2 py-1 font-mono text-xs text-cyber-white focus:border-cyber-orange focus:outline-none" />
              </div>
            </div>
            <div>
              <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Color borde hover</label>
              <div class="flex items-center gap-2">
                <input type="color" value={svc.colors.hoverBorderColor}
                  class="w-8 h-8 border border-cyber-border bg-cyber-black cursor-pointer"
                  oninput={`this.nextElementSibling.value=this.value`} />
                <input type="text" name={`color_hover_${svc.id}`} value={svc.colors.hoverBorderColor}
                  class="flex-1 bg-cyber-black border border-cyber-border px-2 py-1 font-mono text-xs text-cyber-white focus:border-cyber-orange focus:outline-none" />
              </div>
            </div>
            <div>
              <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Color borde tags</label>
              <div class="flex items-center gap-2">
                <input type="color" value={svc.colors.tagBorderColor}
                  class="w-8 h-8 border border-cyber-border bg-cyber-black cursor-pointer"
                  oninput={`this.nextElementSibling.value=this.value`} />
                <input type="text" name={`color_tag_${svc.id}`} value={svc.colors.tagBorderColor}
                  class="flex-1 bg-cyber-black border border-cyber-border px-2 py-1 font-mono text-xs text-cyber-white focus:border-cyber-orange focus:outline-none" />
              </div>
            </div>
          </div>
        </details>
      </div>
    ))}

    {services.length > 0 && (
      <button type="submit" class="btn-primary text-xs py-3 px-6">
        Guardar todos los servicios
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      </button>
    )}
  </form>

  {services.length === 0 && (
    <div class="card-brutal p-8 text-center">
      <p class="text-cyber-text font-mono text-sm">No hay servicios. Crea uno para empezar.</p>
    </div>
  )}

  {/* Hidden delete form */}
  <form method="POST" id="delete-form" class="hidden">
    <input type="hidden" name="_action" value="delete" />
    <input type="hidden" name="delete_id" id="delete-id" value="" />
  </form>

  <script>
    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.id;
        const name = (btn as HTMLElement).dataset.name;
        if (confirm(`¿Eliminar el servicio "${name}"?`)) {
          const form = document.getElementById('delete-form') as HTMLFormElement;
          const input = document.getElementById('delete-id') as HTMLInputElement;
          input.value = id || '';
          form.submit();
        }
      });
    });
  </script>
</AdminLayout>
