---
import Layout from '../layouts/Layout.astro';
import HomePage from '../components/HomePage.astro';
import '../styles/global.css';
import { getTranslations } from '../i18n';

const t = getTranslations('es');

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "CIBAI.Studio",
  "url": "https://cibai.studio",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://cibai.studio/?s={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": t.faq.items.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

// Hero services ItemList — makes individual services indexable by Google crawlers
const heroItemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Servicios CIBAI.Studio",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Automatización de Procesos Empresariales con IA",
      "description": "Automatización de procesos empresariales con IA — recupera tiempo y eficiencia operativa"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Agentes IA, Chatbots RAG y Voz Inteligente para Empresas",
      "description": "Agentes IA, chatbots RAG y voz inteligente para empresas — atención 24/7 y conversión mejorada"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Desarrollo Web, Ecommerce y Software Empresarial",
      "description": "Desarrollo web corporativo, ecommerce a medida y software empresarial — Barcelona, España"
    }
  ]
};
---

<Layout
  title={t.meta.title}
  description={t.meta.description}
  locale="es"
  canonicalPath="/"
  hreflangEs="https://cibai.studio/"
  hreflangCa="https://cibai.studio/ca/"
  schemaMarkup={[websiteSchema, faqSchema, heroItemListSchema]}
>
  <HomePage locale="es" />
</Layout>
