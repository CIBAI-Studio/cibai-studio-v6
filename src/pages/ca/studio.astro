---
import Layout from '../../layouts/Layout.astro';
import StudioPage from '../../components/StudioPage.astro';
import '../../styles/global.css';
import { getTranslations } from '../../i18n';

const t = getTranslations('ca');

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Matías Oliver",
  "jobTitle": "Founder & Strategy Lead",
  "worksFor": {
    "@type": "Organization",
    "name": "CIBAI.Studio",
    "url": "https://cibai.studio"
  },
  "description": "Especialitzat en IA aplicada, automatització i estratègia orientada a negoci. Lidera la visió de CIBAI.Studio.",
  "url": "https://cibai.studio/ca/studio"
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inici",
      "item": "https://cibai.studio/ca/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Studio",
      "item": "https://cibai.studio/ca/studio"
    }
  ]
};

const combinedSchema = [personSchema, breadcrumbSchema];
---

<Layout
  title={t.meta.studio_title}
  description={t.meta.studio_description}
  locale="ca"
  canonicalPath="/ca/studio"
  pageSchema={combinedSchema}
>
  <StudioPage locale="ca" />
</Layout>
