---
import Layout from '../../layouts/Layout.astro';
import HomePage from '../../components/HomePage.astro';
import '../../styles/global.css';
import { getTranslations } from '../../i18n';

const t = getTranslations('ca');

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "CIBAI.Studio",
  "url": "https://cibai.studio",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://cibai.studio/?s={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": t.faq.items.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

// Hero services ItemList (CA) — makes individual services indexable by Google crawlers
const heroItemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Serveis CIBAI.Studio",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Automatització de Processos Empresarials amb IA",
      "description": "Automatització de processos empresarials amb IA — recupera temps i eficiència operativa"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Agents IA, Chatbots RAG i Veu Intel·ligent per a Empreses",
      "description": "Agents IA, chatbots RAG i veu intel·ligent per a empreses — atenció 24/7 i conversió millorada"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Desenvolupament Web, Ecommerce i Programari Empresarial",
      "description": "Desenvolupament web corporatiu, ecommerce a mida i programari empresarial — Barcelona, Catalunya"
    }
  ]
};
---

<Layout
  title={t.meta.title}
  description={t.meta.description}
  locale="ca"
  canonicalPath="/ca/"
  hreflangEs="https://cibai.studio/"
  hreflangCa="https://cibai.studio/ca/"
  schemaMarkup={[websiteSchema, faqSchema, heroItemListSchema]}
>
  <HomePage locale="ca" />
</Layout>
